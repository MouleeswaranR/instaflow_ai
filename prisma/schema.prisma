generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// Auth.js Models
// ============================================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts           Account[]
  sessions           Session[]
  posts              Post[]
  scheduledPosts     ScheduledPost[]
  instagramAccounts  InstagramAccount[]
  githubIntegration  GitHubIntegration?
  leetcodeIntegration LeetCodeIntegration?
  analyticsSnapshots AnalyticsSnapshot[]
  aiConversations    AIConversation[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================================
// Post & Content Models
// ============================================================

enum PostStatus {
  DRAFT
  GENERATED
  SCHEDULED
  PUBLISHING
  PUBLISHED
  FAILED
}

enum PostCategory {
  CODING
  FITNESS
  STARTUP
  STUDY
  ACHIEVEMENT
  QUOTE
  PRODUCT
  OTHER
}

enum PostLayout {
  SINGLE
  CAROUSEL
  STORY
}

model Post {
  id              String       @id @default(cuid())
  userId          String
  title           String
  description     String       @db.Text
  category        PostCategory @default(OTHER)
  achievementType String?
  notes           String?      @db.Text
  status          PostStatus   @default(DRAFT)
  layout          PostLayout   @default(SINGLE)
  theme           String       @default("dark")
  font            String       @default("modern")
  publishedAt     DateTime?
  instagramPostId String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  captions            Caption[]
  hashtagSets         HashtagSet[]
  generatedImages     GeneratedImage[]
  carouselSlides      CarouselSlide[]
  musicRecommendations MusicRecommendation[]
  scheduledPost       ScheduledPost?

  @@index([userId])
  @@index([status])
}

enum CaptionType {
  SHORT
  PROFESSIONAL
  VIRAL
  STORY
  LINKEDIN
}

model Caption {
  id        String      @id @default(cuid())
  postId    String
  type      CaptionType
  content   String      @db.Text
  selected  Boolean     @default(false)
  createdAt DateTime    @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
}

enum HashtagType {
  TRENDING
  NICHE
  MIXED
}

model HashtagSet {
  id        String      @id @default(cuid())
  postId    String
  type      HashtagType
  hashtags  String[]
  selected  Boolean     @default(false)
  createdAt DateTime    @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
}

model GeneratedImage {
  id            String   @id @default(cuid())
  postId        String
  cloudinaryUrl String
  publicId      String
  template      String
  theme         String
  width         Int
  height        Int
  isSelected    Boolean  @default(false)
  createdAt     DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
}

model CarouselSlide {
  id            String   @id @default(cuid())
  postId        String
  slideNumber   Int
  title         String
  content       String   @db.Text
  imageUrl      String?
  publicId      String?
  createdAt     DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
}

model MusicRecommendation {
  id              String   @id @default(cuid())
  postId          String
  songName        String
  artist          String
  mood            String
  popularityScore Int
  selected        Boolean  @default(false)
  createdAt       DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
}

// ============================================================
// Scheduling
// ============================================================

enum ScheduleFrequency {
  ONCE
  DAILY
  WEEKLY
  MONTHLY
}

model ScheduledPost {
  id          String            @id @default(cuid())
  postId      String            @unique
  userId      String
  scheduledAt DateTime
  timezone    String            @default("UTC")
  frequency   ScheduleFrequency @default(ONCE)
  isActive    Boolean           @default(true)
  lastRunAt   DateTime?
  nextRunAt   DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([scheduledAt])
  @@index([isActive, nextRunAt])
}

// ============================================================
// Instagram Integration
// ============================================================

model InstagramAccount {
  id                  String   @id @default(cuid())
  userId              String
  instagramUserId     String   @unique
  username            String
  accessToken         String   @db.Text
  tokenExpiresAt      DateTime
  profilePictureUrl   String?
  followersCount      Int      @default(0)
  followingCount      Int      @default(0)
  mediaCount          Int      @default(0)
  isActive            Boolean  @default(true)
  connectedAt         DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ============================================================
// Platform Integrations
// ============================================================

model GitHubIntegration {
  id              String   @id @default(cuid())
  userId          String   @unique
  githubUsername  String
  accessToken     String   @db.Text
  publicRepos     Int      @default(0)
  followers       Int      @default(0)
  streak          Int      @default(0)
  lastSyncAt      DateTime?
  autoPost        Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LeetCodeIntegration {
  id              String   @id @default(cuid())
  userId          String   @unique
  username        String
  totalSolved     Int      @default(0)
  easySolved      Int      @default(0)
  mediumSolved    Int      @default(0)
  hardSolved      Int      @default(0)
  contestRating   Int      @default(0)
  streak          Int      @default(0)
  lastSyncAt      DateTime?
  autoPost        Boolean  @default(false)
  postOnStreak    Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============================================================
// Analytics
// ============================================================

model AnalyticsSnapshot {
  id          String   @id @default(cuid())
  userId      String
  date        DateTime @db.Date
  likes       Int      @default(0)
  comments    Int      @default(0)
  reach       Int      @default(0)
  impressions Int      @default(0)
  saves       Int      @default(0)
  shares      Int      @default(0)
  followers   Int      @default(0)
  postsCount  Int      @default(0)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
}

// ============================================================
// AI Agent
// ============================================================

model AIConversation {
  id        String      @id @default(cuid())
  userId    String
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  messages AIMessage[]
  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum MessageRole {
  USER
  ASSISTANT
}

model AIMessage {
  id             String     @id @default(cuid())
  conversationId String
  role           MessageRole
  content        String     @db.Text
  metadata       Json?
  createdAt      DateTime   @default(now())

  conversation AIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}
